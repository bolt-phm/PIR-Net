{
  "project": {
    "name": "BoltLooseningBaseline",
    "version": "baseline-304-spec-resnet18",
    "exp_id": "304",
    "description": "2D CNN baseline: ResNet-18 on standard log-spectrogram RGB (no PIR preprocessing)."
  },
  "data": {
    "data_dir": "/path/to/your/dataset",
    "data_format": ".npy",
    "sr": 1000000,
    "case_ids": [
      "SevereLoose",
      "Loose",
      "Critical",
      "Transition",
      "Secure",
      "OverTight"
    ],
    "num_classes": 6,
    "fusion_map": {
      "case1": 0,
      "case2": 0,
      "case3": 0,
      "case4": 1,
      "case5": 1,
      "case6": 2,
      "case7": 2,
      "case8": 2,
      "case9": 3,
      "case10": 3,
      "case11": 3,
      "case12": 4,
      "case13": 4,
      "case14": 4,
      "case15": 5,
      "case16": 5
    },
    "global_scale": 276.0,
    "target_signal_len": 8192,
    "base_resample_factor": 150,
    "signal_preprocess": "linear",
    "image_preprocess": "spectrogram_rgb",
    "image_size": [
      224,
      224
    ],
    "spectrogram_fs": 1000000,
    "stft_nperseg": 128,
    "stft_overlap_ratio": 0.5,
    "split_mode": "temporal",
    "split_ratio": [
      0.7,
      0.15,
      0.15
    ],
    "step_ratio": 0.1,
    "file_split_seed": 3407,
    "batch_size": 160,
    "num_workers": 12,
    "use_whitelist": false,
    "whitelist": [],
    "prefetch_factor": 6
  },
  "augment": {
    "signal": {
      "use_augment": false,
      "params": {}
    }
  },
  "model": {
    "name": "spec_resnet18",
    "dropout": 0.0,
    "pretrained": false
  },
  "train": {
    "seed": 3407,
    "device": "cuda",
    "epochs": 100,
    "learning_rate": 0.00025,
    "weight_decay": 0.0001,
    "optimizer": "adamw",
    "use_cosine": true,
    "early_stopping_patience": 20,
    "class_weights": [
      1.3,
      1.1,
      1.0,
      1.0,
      2.0,
      1.5
    ],
    "best_model_name": "best_model.pth",
    "log_dir": "./logs",
    "model_dir": "./checkpoints",
    "amp": true
  }
}
